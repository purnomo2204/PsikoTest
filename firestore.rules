rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: student, teacher, admin)
    //   - classId: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: test_results
    // Document ID: auto-generated
    // Fields:
    //   - studentId: string (required)
    //   - studentName: string (required)
    //   - testType: string (required, enum: learning_style, multiple_intelligences, personality, aptitude_interest, school_major, anxiety)
    //   - scores: map (required)
    //   - analysis: string (required)
    //   - timestamp: timestamp (required)
    //
    // Collection: classes
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - teacherId: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email.lower() == "purnomowiwit@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.role in ['student', 'teacher', 'admin'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidTestResult(data) {
      return data.keys().hasAll(['studentId', 'studentName', 'testType', 'scores', 'analysis', 'timestamp']) &&
             data.studentId is string &&
             data.studentName is string && data.studentName.size() > 0 && data.studentName.size() < 100 &&
             data.testType in ['learning_style', 'multiple_intelligences', 'personality', 'aptitude_interest', 'school_major', 'anxiety'] &&
             data.scores is map &&
             data.analysis is string &&
             (data.timestamp is timestamp || data.timestamp == request.time);
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == 'student' || (request.resource.data.role == 'admin' && request.resource.data.email.lower() == "purnomowiwit@gmail.com"));
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /test_results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentId && isValidTestResult(request.resource.data);
      allow delete: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /teacher_settings/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid) && (isAdmin() || isTeacher());
    }

    match /custom_tests/{testId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isTeacher();
    }
  }
}
