rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - role: string (required, enum: student, teacher, admin)
    //   - classId: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: test_results
    // Document ID: auto-generated
    // Fields:
    //   - studentId: string (required)
    //   - studentName: string (required)
    //   - testType: string (required, enum: learning_style, multiple_intelligences, personality, aptitude_interest, school_major, anxiety)
    //   - scores: map (required)
    //   - analysis: string (required)
    //   - timestamp: timestamp (required)
    //
    // Collection: classes
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - teacherId: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.get('email', '').lower() in ["dutatama@gmail.com", "purnomowiwit@gmail.com"] && request.auth.token.get('email_verified', false) == true));
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.role in ['student', 'teacher', 'admin'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidTestResult(data) {
      return data.keys().hasAll(['studentId', 'studentName', 'testType', 'scores', 'analysis', 'timestamp', 'teacherId']) &&
             data.studentId is string &&
             data.teacherId is string &&
             data.studentName is string && data.studentName.size() > 0 && data.studentName.size() < 100 &&
             data.testType in ['learning_style', 'multiple_intelligences', 'personality', 'aptitude_interest', 'school_major', 'anxiety', 'wartegg', 'school_career', 'subject_interest', 'cfit'] &&
             data.scores is map &&
             data.analysis is string &&
             (data.timestamp is timestamp || data.timestamp == request.time) &&
             (!('aiExplanation' in data) || (data.aiExplanation is string && data.aiExplanation.size() < 50000)) &&
             (!('visualizationType' in data) || data.visualizationType == null || data.visualizationType is string);
    }

    function isValidCounselingLog(data) {
      return data.keys().hasAll(['studentId', 'teacherId', 'date', 'topic', 'notes', 'interventionStatus', 'timestamp']) &&
             data.studentId is string &&
             data.teacherId is string &&
             data.date is string &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 200 &&
             data.notes is string && data.notes.size() > 0 && data.notes.size() < 5000 &&
             data.interventionStatus in ['pending', 'in-progress', 'completed'] &&
             (data.timestamp is timestamp || data.timestamp == request.time);
    }

    function isEmergencyUser(uid) {
      return uid is string && uid.matches("^local_.*");
    }

    function isLegacyAdmin() {
      return isAuthenticated() && request.auth.token.get('email', '').lower() == "purnomowiwit@gmail.com";
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow create, update: if isEmergencyUser(uid) || isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /test_results/{resultId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.studentId) || isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')));
      allow create: if (isEmergencyUser(request.resource.data.studentId) || (isAuthenticated() && request.auth.uid == request.resource.data.studentId) || isAdmin() || isTeacher()) && isValidTestResult(request.resource.data);
      allow update: if (isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin'))) || (isAuthenticated() && request.auth.uid == resource.data.studentId) || isEmergencyUser(resource.data.studentId))
                    && isValidTestResult(request.resource.data) && (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiExplanation']));
      allow delete: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')));
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /students/{studentId} {
      allow read: if true;
      allow create: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin() || (isTeacher() && (resource.data.addedBy == request.auth.uid || (isLegacyAdmin() && resource.data.addedBy == 'admin')));
    }

    match /teacher_settings/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) && (isAdmin() || isTeacher());
    }

    match /custom_tests/{testId} {
      allow read: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin'))) || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teacherId == resource.data.teacherId);
      allow create: if isAdmin() || isTeacher();
      allow update, delete: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')));
    }

    match /notifications/{notifId} {
      allow read: if isAdmin() || (isAuthenticated() && (
        (request.auth.uid == resource.data.userId) || 
        (resource.data.userId == 'all' && resource.data.teacherId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teacherId) || 
        (resource.data.userId.matches("^class:.*") && resource.data.teacherId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teacherId) ||
        (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')))
      ));
      allow create: if true;
      allow update: if isAuthenticated() && (
        (request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])) ||
        isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')))
      );
      allow delete: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')));
    }

    match /counseling_logs/{logId} {
      allow read: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin'))) || (isAuthenticated() && request.auth.uid == resource.data.studentId && !resource.data.isPrivate);
      allow create: if (isAdmin() || isTeacher()) && isValidCounselingLog(request.resource.data);
      allow update: if (isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')))) && isValidCounselingLog(request.resource.data);
      allow delete: if isAdmin() || (isTeacher() && (resource.data.teacherId == request.auth.uid || (isLegacyAdmin() && resource.data.teacherId == 'admin')));
    }
  }
}
